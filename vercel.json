{
  "buildCommand": "pnpm --filter @workspace/terminal-chat run build",
  "outputDirectory": "artifacts/terminal-chat/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
